# =============================================================================
# Apollyon - AI Decision Support Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# All AI features can be toggled on/off with AI_ENABLED.
# =============================================================================

# --- General Settings ---
# Enable or disable all AI features (true/false)
AI_ENABLED=true

# LLM Provider: 'openai', 'anthropic', 'ollama', 'litellm'
AI_PROVIDER=ollama

# Temperature (0.0-2.0): Higher = more creative, Lower = more deterministic
AI_TEMPERATURE=0.3

# Maximum tokens in the response
AI_MAX_TOKENS=2048

# Request timeout in seconds
AI_TIMEOUT_SECONDS=60

# --- OpenAI / Compatible APIs ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# For compatible providers (Groq, Together, etc.), change this URL:
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Ollama (Local LLM) ---
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- LiteLLM (Unified Interface) ---
# Use this for a single interface across multiple providers
LITELLM_PROVIDER=openai
LITELLM_MODEL=gpt-4o
LITELLM_API_KEY=sk-...
LITELLM_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Quick Start:
#   1. Copy this file: cp .env.example .env
#   2. Edit .env with your API keys or local Ollama settings
#   3. Install dependencies: pip install -r requirements.txt
# =============================================================================